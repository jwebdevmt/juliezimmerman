<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} | {{ site_title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="stylesheet" href="{{ asset_prefix }}assets/style.css">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset_prefix }}assets/images/favicon.png">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset_prefix }}assets/images/favicon.png">
  <link rel="apple-touch-icon" href="{{ asset_prefix }}assets/images/favicon.png">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-KE14CPL09E"></script>
  <script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-KE14CPL09E');
  </script>
</head>
<body>
  <header class="site-header">
    <div class="site-shell navbar">
      <a class="brand-mini" href="{{ asset_prefix }}index.html">
        <img class="brand-mark" src="{{ asset_prefix }}assets/brand-mark.svg" alt="">
        <span>{{ owner_name }}</span>
      </a>
      <nav class="nav-links" aria-label="Main navigation">
        {{ nav_links }}
      </nav>
    </div>
  </header>

  {{ content }}

  <footer class="site-footer">
    <div class="site-shell footer-grid">
      <div>
        <img class="footer-logo" src="{{ asset_prefix }}assets/jz-logo.png" alt="{{ owner_name }}">
        <p class="footer-note">{{ footer_note }}</p>
      </div>
      <div class="footer-links">
        <a href="{{ asset_prefix }}about.html">About</a>
        <a href="{{ asset_prefix }}writing.html">Writing</a>
        <a href="{{ asset_prefix }}contact.html">Contact</a>
      </div>
    </div>
  </footer>
</body>
</html>
